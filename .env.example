# Marketplace Compare Sheet — пример конфигурации
# Скопируй в .env и при необходимости измени значения

# Окружение: development | production
APP_ENV=development

# Хост и порт сервера
HOST=0.0.0.0
PORT=8000

# Режим по умолчанию: demo | live_public
DEFAULT_MODE=demo

# Таймаут HTTP запросов к маркетплейсам (секунды)
HTTP_TIMEOUT=10.0

# Максимальное количество результатов на запрос
MAX_TOP_N=50

# API ключ для опциональной авторизации (оставь пустым если не нужен)
API_KEY=

# Ozon Seller API ключ (нужен для live_public режима Ozon)
# Получить: https://seller.ozon.ru/app/settings/api-keys
OZON_API_KEY=
